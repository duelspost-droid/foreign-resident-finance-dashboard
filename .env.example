# ── Supabase ──────────────────────────────────────────────────────────────
# 브라우저(관리자 승인 페이지)용 — anon 키만 노출 가능(service_role 절대 금지)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버/배치(load_supabase, sync_candidates)용
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 공공데이터포털(data.go.kr) 오픈API 서비스키 (REST openapi 수집용)
# 발급: https://www.data.go.kr 로그인 → 마이페이지 → 인증키 발급/관리 (Decoding 키 권장)
DATA_GO_KR_SERVICE_KEY=

# KOSIS 국가통계포털 오픈API 인증키 (통계 수집용)
# 발급: https://kosis.kr/openapi → 활용신청 → 사용자 인증키
KOSIS_API_KEY=
